{
  "version": "1.0",
  "policy": "block",
  "description": "Security guardrail ruleset. Categories mirror Microsoft Defender real-time agent protection threat classes.",
  "rules": [
    { "id": "destructive-fs", "category": "destructive-action", "severity": "high",
      "match": ["rm\\s+-rf\\s+/", "rm\\s+-rf\\s+~", "Remove-Item.+-Recurse.+-Force.+[A-Za-z]:\\\\", "mkfs", "dd\\s+if=.*of=/dev/"],
      "message": "Destructive filesystem command." },
    { "id": "credential-leak", "category": "credential-leakage", "severity": "high",
      "match": ["AKIA[0-9A-Z]{16}", "-----BEGIN (RSA|OPENSSH|PRIVATE) KEY-----", "ghp_[0-9A-Za-z]{36}", "xox[baprs]-[0-9A-Za-z-]+", "(?i)password\\s*=\\s*['\"][^'\"]{6,}"],
      "message": "Potential credential leakage." },
    { "id": "exfiltration", "category": "untrusted-routing", "severity": "high",
      "match": ["curl.+(-d|--data).+http", "Invoke-WebRequest.+-Body.+http", "(curl|wget).+https?://[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+", "nc\\s+-e", "(scp|sftp|rsync)\\s+.+@[0-9]+\\.[0-9]+\\.[0-9]+\\.[0-9]+", "scp\\s+.+@.+:"],
      "message": "Data exfiltration to untrusted destination." },
    { "id": "internal-tool-misuse", "category": "tool-misuse", "severity": "medium",
      "match": ["git\\s+push\\s+--force\\s+origin\\s+(main|master)", "history\\s+-c"],
      "message": "Risky tool misuse." },
    { "id": "obfuscation", "category": "obfuscated-content", "severity": "medium",
      "match": ["base64\\s+-d.+\\|\\s*(sh|bash)", "IEX\\s*\\(.*FromBase64String", "eval\\(atob\\("],
      "message": "Obfuscated execution chain." }
  ],
  "allowlist": ["rm -rf node_modules", "rm -rf dist", "rm -rf build"]
}
